    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>/AlgorithmBitPattern</IRI>
        <Literal xml:lang="en">A quality of computational hardware that is the physical bit-level encoding of a machine learning model.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#example"/>
        <IRI>/AlgorithmBitPattern</IRI>
