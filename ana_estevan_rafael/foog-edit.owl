SubObjectPropertyOf(<http://purl.obolibrary.org/obo/FOOG_0000011> owl:topObjectProperty)

# Object Property: <http://purl.obolibrary.org/obo/FOOG_0000012> (parte do sistema de)

AnnotationAssertion(dcterms:description <http://purl.obolibrary.org/obo/FOOG_0000012> "É uma relação que liga um site menor a um site que ele faz parte."@pt-br)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FOOG_0000012> "part of system site"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/FOOG_0000012> "parte do sistema de"@pt-br)
SubObjectPropertyOf(<http://purl.obolibrary.org/obo/FOOG_0000012> owl:topObjectProperty)

# Object Property: <http://purl.obolibrary.org/obo/FOOG_0000017> (is state of)

