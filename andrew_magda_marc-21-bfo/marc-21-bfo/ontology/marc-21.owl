        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#is_about</IRI>
        <Literal xml:lang="en-us">A relation between an information content entity (like a log record) and the real-world independent continuant it references or reports.</Literal>
    </AnnotationAssertion>
