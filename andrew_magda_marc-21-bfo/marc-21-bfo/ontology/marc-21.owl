        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000112"/>
        <IRI>#record_update_process</IRI>
        <Literal xml:lang="en-us">A cataloger updates a MARC 21 record by adding missing subject headings.</Literal>
