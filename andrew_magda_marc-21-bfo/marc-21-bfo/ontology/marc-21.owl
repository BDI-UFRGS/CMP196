        <IRI>#item_availability</IRI>
        <Literal xml:lang="pt-br">A disponibilidade de um exemplar pode variar ao longo do tempo em decorrência de processos de circulação como empréstimos, devoluções, reservas ou extravios.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#item_availability</IRI>
        <Literal xml:lang="en-us">The availability of a bibliographic item may change over time as a consequence of circulation processes such as loans, returns, reservations, or losses.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#item_availability</IRI>
        <Literal xml:lang="en-us">A relational quality that inheres in a bibliographic item and reflects its current accessibility status within a library circulation context.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
