        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000600"/>
        <IRI>#is_about</IRI>
        <Literal xml:lang="en-us">A mapping derived from the Information Artifact Ontology (IAO) stating that an informational text or artifact points to, or registers information regarding, a concrete entity.</Literal>
    </AnnotationAssertion>
