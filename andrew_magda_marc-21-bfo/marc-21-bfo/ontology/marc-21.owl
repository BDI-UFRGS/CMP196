    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#record_completeness_specification</IRI>
        <Literal xml:lang="en-us">An informational specification entity (metadata) associated with a BibliographicRecord that indicates its structural enrichment and data density level (e.g., Complete if it contains all mandatory tags, or Partial if it is a preliminary draft), objectively evaluated based on MARC 21 standard rules.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#record_completeness_specification</IRI>
        <Literal xml:lang="pt-br">É a entidade de especificação informacional (metadado) associada a um BibliographicRecord que indica o seu nível de detalhamento e preenchimento estrutural (ex: Completo se contiver todas as tags obrigatórias, ou Parcial se for um rascunho preliminar), avaliada objetivamente com base nas regras normativas do formato MARC 21.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        <IRI>#record_completeness_specification</IRI>
        <Literal xml:lang="pt-br">Especificação de Completude do Registro</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        <IRI>#record_completeness_specification</IRI>
        <Literal xml:lang="en-us">Record Completeness Specification</Literal>
    </AnnotationAssertion>
