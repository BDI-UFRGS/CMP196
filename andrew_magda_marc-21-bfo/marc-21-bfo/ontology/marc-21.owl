    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000600"/>
        <IRI>#represents_work</IRI>
        <Literal xml:lang="pt-br">Permite que os sistemas de busca saibam para qual criação abstrata central um registro específico aponta, ignorando as camadas de expressão/manifestação para fins de recuperação analítica.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000600"/>
        <IRI>#represents_work</IRI>
