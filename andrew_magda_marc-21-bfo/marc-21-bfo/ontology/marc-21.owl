    <AnnotationAssertion>
        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000112"/>
        <IRI>#has_role</IRI>
        <Literal xml:lang="pt-br">esta pessoa possui_papel este papel de autor; esta pessoa possui_papel este papel de catalogador.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000112"/>
        <IRI>#has_role</IRI>
        <Literal xml:lang="en-us">this person has_role this author role; this person has_role this cataloger role.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000600"/>
        <IRI>#has_role</IRI>
        <Literal xml:lang="en-us">b has_role c at t means that b is an independent continuant, c is a role, and c inheres in b at time t. The role c is not essential to the physical existence of b, but defines a context or behavior that b can exhibit.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000600"/>
        <IRI>#has_role</IRI>
        <Literal xml:lang="pt-br">b possui_papel c em t significa que b é um continuante independente, c é um papel, e c inere em b no tempo t. O papel c não é essencial para a existência física de b, mas define um contexto ou comportamento que b pode manifestar.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#has_role</IRI>
        <Literal xml:lang="en-us">A relation between an independent continuant (the bearer) and a role specifically dependent on it.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#has_role</IRI>
        <Literal xml:lang="pt-br">Uma relação entre um continuante independente (o portador) e um papel (role) especificamente dependente dele.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#prefLabel"/>
        <IRI>#has_role</IRI>
        <Literal xml:lang="en-us">Has Role</Literal>
    </AnnotationAssertion>
