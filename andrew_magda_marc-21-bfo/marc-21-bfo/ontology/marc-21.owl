    <Annotation>
        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <Literal xml:lang="en-us">MARC21-BFO is an ontology that aligns MARC 21 bibliographic concepts with BFO, IAO, RO and FRBR to provide a semantically grounded representation of bibliographic catalogs and library processes.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty IRI="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <Literal xml:lang="pt-br">MARC21-BFO é uma ontologia que alinha os conceitos bibliográficos do MARC 21 com BFO, IAO, RO e FRBR para fornecer uma representação semanticamente fundamentada de catálogos bibliográficos e processos de biblioteca.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty IRI="http://purl.org/dc/elements/1.1/creator"/>
        <Literal xml:lang="en-us">Andrew Paes da Silva; Mara Magda;</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty IRI="http://purl.org/dc/elements/1.1/description"/>
        <Literal xml:lang="pt-br">Ontologia que alinha conceitos bibliográficos do MARC 21 com BFO, IAO, RO e FRBR para interoperabilidade semântica e engenharia de ontologias baseada no realismo.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty IRI="http://purl.org/dc/elements/1.1/description"/>
        <Literal xml:lang="en-us">Ontology aligning MARC 21 bibliographic concepts with BFO, IAO, RO and FRBR for semantic interoperability and realism-based ontology engineering.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty IRI="http://purl.org/dc/elements/1.1/license"/>
        <Literal xml:lang="en-us">GNU General Public License v2.0</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty IRI="http://purl.org/dc/elements/1.1/publisher"/>
        <Literal xml:lang="en-us">UFRGS - Universidade Federal do Rio Grande do Sul</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty IRI="http://purl.org/dc/elements/1.1/title"/>
        <Literal xml:lang="en-us">MARC21-BFO Ontology</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty IRI="http://purl.org/dc/elements/1.1/title"/>
        <Literal xml:lang="pt-br">Ontologia MARC21-BFO</Literal>
    </Annotation>
