        <AnnotationProperty IRI="http://www.w3.org/2004/02/skos/core#definition"/>
        <IRI>#loan_record</IRI>
        <Literal xml:lang="en-us">A MARC 21 record that has been textually modified in written form. It is not a free narrative document, but rather structured strings that carry information. An informational piece of log data or transaction record that permanently attests the historical loan transaction between a reader and an item.</Literal>
    </AnnotationAssertion>
