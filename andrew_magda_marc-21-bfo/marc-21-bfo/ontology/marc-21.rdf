        <exemplifies_manifestation rdf:resource="http://purl.org/marc-21/ontology#inst_garnier_1899_manifestation"/>
        <owned_by rdf:resource="http://purl.org/marc-21/ontology#inst_City_Library"/>
        <rdfs:comment xml:lang="pt-br">O objeto livro tangível e macroscópico localizado na estante da biblioteca.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">The tangible macroscopical book item located on the library shelf.</rdfs:comment>
        <rdfs:label xml:lang="en-us">Dom Casmurro (1899 Physical Copy)</rdfs:label>
        <rdfs:label xml:lang="pt-br">Dom Casmurro (Exemplar Físico de 1899)</rdfs:label>
    </owl:NamedIndividual>
    


