        <has_role rdf:resource="http://purl.org/marc-21/ontology#inst_role_joao_reader"/>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_Local_HD_Server -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_Local_HD_Server">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#catalog_carrier"/>
        <rdfs:comment xml:lang="pt-br">O hardware físico portador onde reside o arquivo do banco de dados.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">The physical hardware carrier where the database file resides.</rdfs:comment>
        <rdfs:label xml:lang="en-us">Local Storage Server</rdfs:label>
        <rdfs:label xml:lang="pt-br">Servidor de Armazenamento Local</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_Machado_de_Assis_Author -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_Machado_de_Assis_Author">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#person"/>
        <has_role rdf:resource="http://purl.org/marc-21/ontology#inst_role_machado_author"/>
        <rdfs:comment xml:lang="pt-br">Renomado escritor e poeta brasileiro, autor de Dom Casmurro.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">Renowned Brazilian novelist and poet, author of Dom Casmurro.</rdfs:comment>
        <rdfs:label xml:lang="en-us">Machado de Assis</rdfs:label>
        <rdfs:label xml:lang="pt-br">Machado de Assis</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_Maria_Cataloger -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_Maria_Cataloger">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#person"/>
        <has_role rdf:resource="http://purl.org/marc-21/ontology#inst_role_maria_cataloger"/>
        <rdfs:comment xml:lang="pt-br">A profissional bibliotecária responsável pelo processamento técnico.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">The professional librarian responsible for technical processing.</rdfs:comment>
        <rdfs:label xml:lang="pt-br">Maria (Catalogadora)</rdfs:label>
        <rdfs:label xml:lang="en-us">Maria (Cataloger)</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_Metailie_Publisher -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_Metailie_Publisher">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#publisher"/>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_available -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_available">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#item_availability"/>
        <obo:IAO_0000112 xml:lang="pt-br">O exemplar tombamento 12345 está disponível para empréstimo.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">The copy Tomb Number 12345 is available for loan.</obo:IAO_0000112>
        <skos:definition xml:lang="en-us">An item availability state indicating that a bibliographic item is accessible for circulation.</skos:definition>
        <skos:definition xml:lang="pt-br">Estado de disponibilidade indicando que um exemplar bibliográfico está acessível para circulação.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Available</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Disponível</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_cataloging_process_001 -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_cataloging_process_001">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#cataloging_process"/>
        <has_input rdf:resource="http://purl.org/marc-21/ontology#inst_garnier_1899_manifestation"/>
        <has_output rdf:resource="http://purl.org/marc-21/ontology#inst_marc21_rec_123"/>
        <has_participant rdf:resource="http://purl.org/marc-21/ontology#inst_Maria_Cataloger"/>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_dom_casmurro_work -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_dom_casmurro_work">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#bibliographic_work"/>
        <has_creator rdf:resource="http://purl.org/marc-21/ontology#inst_Machado_de_Assis_Author"/>
        <rdfs:label xml:lang="pt-br">Dom Casmurro (Obra)</rdfs:label>
        <rdfs:label xml:lang="en-us">Dom Casmurro (Work)</rdfs:label>
        <skos:definition xml:lang="pt-br">A criação intelectual abstrata da história de Dom Casmurro, concebida por Machado de Assis.</skos:definition>
        <skos:definition xml:lang="en-us">The abstract intellectual creation of the story of Dom Casmurro by Machado de Assis.</skos:definition>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_english_translation_expression -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_english_translation_expression">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#bibliographic_expression"/>
        <is_expression_of rdf:resource="http://purl.org/marc-21/ontology#inst_dom_casmurro_work"/>
        <rdfs:label xml:lang="en-us">English Translation Expression</rdfs:label>
        <rdfs:label xml:lang="pt-br">Expressão de Tradução em Inglês</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_garnier_1899_manifestation -->

