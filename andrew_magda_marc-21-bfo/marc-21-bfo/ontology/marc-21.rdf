<?xml version="1.0"?>
<rdf:RDF xmlns="http://purl.org/marc-21/ontology#"
     xml:base="http://purl.org/marc-21/ontology"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:obo="http://purl.obolibrary.org/obo/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:cito="http://purl.org/spar/cito/"
     xmlns:core="http://purl.obolibrary.org/obo/uberon/core#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:mbfo="http://purl.org/marc-21/ontology#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:protege="http://protege.stanford.edu/plugins/owl/protege#"
     xmlns:subsets="http://purl.obolibrary.org/obo/ro/subsets#"
     xmlns:oboInOwl="http://www.geneontology.org/formats/oboInOwl#">
    <owl:Ontology rdf:about="http://purl.org/marc-21/ontology">
        <owl:versionIRI rdf:resource="http://purl.org/marc-21/releases/1.0"/>
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/bfo/2020/bfo.owl"/>
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/iao/2026-03-30/iao.owl"/>
        <owl:imports rdf:resource="http://purl.obolibrary.org/obo/ro/releases/2025-12-17/ro.owl"/>
        <obo:IAO_0000115 xml:lang="en-us">MARC21-BFO is an ontology that aligns MARC 21 bibliographic concepts with BFO, IAO, RO and FRBR to provide a semantically grounded representation of bibliographic catalogs and library processes.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">MARC21-BFO é uma ontologia que alinha os conceitos bibliográficos do MARC 21 com BFO, IAO, RO e FRBR para fornecer uma representação semanticamente fundamentada de catálogos bibliográficos e processos de biblioteca.</obo:IAO_0000115>
        <dc:creator xml:lang="en-us">Andrew Paes da Silva; Mara Magda;</dc:creator>
        <dc:description xml:lang="pt-br">Ontologia que alinha conceitos bibliográficos do MARC 21 com BFO, IAO, RO e FRBR para interoperabilidade semântica e engenharia de ontologias baseada no realismo.</dc:description>
        <dc:description xml:lang="en-us">Ontology aligning MARC 21 bibliographic concepts with BFO, IAO, RO and FRBR for semantic interoperability and realism-based ontology engineering.</dc:description>
        <dc:license xml:lang="en-us">GNU General Public License v2.0</dc:license>
        <dc:publisher xml:lang="en-us">UFRGS - Universidade Federal do Rio Grande do Sul</dc:publisher>
        <dc:title xml:lang="en-us">MARC21-BFO Ontology</dc:title>
        <dc:title xml:lang="pt-br">Ontologia MARC21-BFO</dc:title>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/marc-21/ontology#cataloged_by -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#cataloged_by">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000112 xml:lang="en-us">MARC 21 record 123 was cataloged_by Maria (the librarian).</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="pt-br">o registro MARC 21 123 foi catalogado_por Maria (a bibliotecária).</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="pt-br">Estabelece uma trilha de auditoria administrativa dentro do grafo, conectando uma entidade de informação a um agente humano atuando sob o papel de catalogador.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="en-us">Establishes an administrative audit trail within the graph, connecting an information entity to a human agent acting under a cataloger role.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation linking a data entity (Bibliographic Record) to the physical person who authored or generated the metadata structure.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação vinculando uma entidade de dados (Registro Bibliográfico) à pessoa física que gerou ou foi autora da estrutura de metadados.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Catalogado por</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Cataloged by</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#describes -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#describes">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000112 xml:lang="pt-br">este fluxo lógico de registro MARC 21 descreve a manifestação Garnier de 1899.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">this MARC 21 logical record stream describes the Garnier 1899 manifestation.</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="en-us">A bibliographic record describes a manifestation by using normative schema fields (like MARC 21 tags) to capture its titles, publishing houses, and technical metadata for retrieval.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="pt-br">Um registro bibliográfico descreve uma manifestação ao usar campos de esquemas normativos (como as tags do MARC 21) para capturar seus títulos, editoras e metadados técnicos para fins de recuperação.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation between a structured metadata record (Bibliographic Record) and the entity it catalogs.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação entre um registro de metadados estruturado (Registro Bibliográfico) e a entidade que ele cataloga.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Descreve</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Describes</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#embodies -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#embodies">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000112 xml:lang="pt-br">a manifestação editorial da Garnier de 1899 corporifica a expressão em texto original em português.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">the Garnier 1899 publishing manifestation embodies the original Portuguese text expression.</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="en-us">A manifestation embodies an expression by defining the commercial, physical, or technical medium parameters (such as typography, layout, or file formatting) used to deliver that expression to an audience.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="pt-br">Uma manifestação corporifica uma expressão ao definir os parâmetros comerciais, físicos ou técnicos do meio (como tipografia, layout ou formatação de arquivo) utilizados para entregar aquela expressão a um público.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation between a production-level informational specification (Manifestation) and the linguistic/textual entity (Expression) it packages for distribution.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação entre uma especificação informacional de nível de produção (Manifestação) e a entidade linguística/textual (Expressão) que ela empacota para distribuição.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Corporifica</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Embodies</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#exemplifies -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#exemplifies">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000112 xml:lang="pt-br">o livro físico em brochura na prateleira 3 com código de barras 4567 exemplifica a manifestação Garnier de 1899.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">the physical paperback book on shelf 3 with barcode 4567 exemplifies the Garnier 1899 manifestation.</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="en-us">An item exemplifies a manifestation when it is a physical token produced according to the characteristics defined by that manifestation blueprint, possessing unique material qualities like a barcode or inventory stamp.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="pt-br">Um item exemplifica uma manifestação quando é um token físico produzido de acordo com as características definidas pelo plano daquela manifestação, possuindo qualidades materiais únicas como um código de barras ou carimbo de inventário.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation between a concrete physical artifact (Item) and the informational production blueprint (Manifestation) it materializes.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação entre um artefato físico concreto (Item) e o plano de produção informacional (Manifestação) que ele materializa.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Exemplifica</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Exemplifies</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#exemplifies_manifestation -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#exemplifies_manifestation">
        <owl:inverseOf rdf:resource="http://purl.org/marc-21/ontology#is_exemplified_by"/>
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#bibliographic_item"/>
        <rdfs:range rdf:resource="http://purl.org/marc-21/ontology#bibliographic_manifestation"/>
        <skos:definition xml:lang="pt-br">Relaciona um item bibliográfico à manifestação bibliográfica que ele exemplifica.</skos:definition>
        <skos:definition xml:lang="en-us">Relates a bibliographic item to the bibliographic manifestation that it exemplifies.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Exemplifica a Manifestação</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Exemplifies Manifestation</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_creator -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#has_creator">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000112 xml:lang="pt-br">a obra bibliográfica &quot;Dom Casmurro&quot; possui_criador a pessoa &quot;Machado de Assis&quot;.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">the bibliographic work &quot;Dom Casmurro&quot; has_creator the person &quot;Machado de Assis&quot;.</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="pt-br">Dizer que uma entidade informacional abstrata possui_criador uma pessoa física é afirmar que a pessoa executou um processo cognitivo ou físico que causou a expressão ou manifestação inicial daquela informação.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="en-us">To say that an abstract informational entity has_creator a physical person is to assert that the person executed a cognitive or physical process that caused the initial expression or manifestation of that information.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation between an informational content entity (such as a Work) and the physical agent (Person or Organization) responsible for its conception or creation.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação entre uma entidade de conteúdo informacional (como uma Obra) e o agente físico (Pessoa ou Organização) responsável por sua concepção ou criação.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Has Creator</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Possui Criador</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_expression -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#has_expression">
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#bibliographic_work"/>
        <rdfs:range rdf:resource="http://purl.org/marc-21/ontology#bibliographic_expression"/>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_input -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#has_input">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <obo:IAO_0000112 xml:lang="en-us">A cataloging process has input a bibliographic manifestation.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="pt-br">Um processo de catalogação tem como entrada uma manifestação bibliográfica.</obo:IAO_0000112>
        <rdfs:comment xml:lang="pt-br">Esta propriedade é usada para representar entidades disponíveis antes ou no início de um processo.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">This property is used to represent the entities available before or at the beginning of a process.</rdfs:comment>
        <skos:definition xml:lang="pt-br">Relaciona um processo a um continuante que participa do processo como entidade de entrada.</skos:definition>
        <skos:definition xml:lang="en-us">Relates a process to a continuant that participates in the process as an input entity.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Has input</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Tem entrada</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_output -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#has_output">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <obo:IAO_0000112 xml:lang="en-us">A cataloging process has output a bibliographic record.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="pt-br">Um processo de catalogação tem como saída um registro bibliográfico.</obo:IAO_0000112>
        <rdfs:comment xml:lang="pt-br">Esta propriedade é usada para continuantes informacionais ou materiais resultantes de um processo.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">This property is used for informational or material continuants that result from a process.</rdfs:comment>
        <skos:definition xml:lang="pt-br">Relaciona um processo a um continuante que é produzido, gerado ou resultante do processo.</skos:definition>
        <skos:definition xml:lang="en-us">Relates a process to a continuant that is produced, generated, or resulting from the process.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Has output</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Tem saída</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_participant -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#has_participant">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <obo:IAO_0000112 xml:lang="en-us">A loan process has participant a person who bears a reader role.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="pt-br">Um processo de empréstimo tem como participante uma pessoa que porta o papel de leitor.</obo:IAO_0000112>
        <rdfs:comment xml:lang="pt-br">Esta propriedade é usada para pessoas, organizações, artefatos, registros, papéis ou outros continuantes envolvidos em um processo.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">This property is used for persons, organizations, artifacts, records, roles, or other continuants involved in a process.</rdfs:comment>
        <skos:definition xml:lang="pt-br">Relaciona um processo a um continuante que participa do processo.</skos:definition>
        <skos:definition xml:lang="en-us">Relates a process to a continuant that participates in the process.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Has participant</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Tem participante</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_role -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#has_role">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#person"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <obo:IAO_0000112 xml:lang="pt-br">esta pessoa possui_papel este papel de autor; esta pessoa possui_papel este papel de catalogador.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">this person has_role this author role; this person has_role this cataloger role.</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="en-us">b has_role c at t means that b is an independent continuant, c is a role, and c inheres in b at time t. The role c is not essential to the physical existence of b, but defines a context or behavior that b can exhibit.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="pt-br">b possui_papel c em t significa que b é um continuante independente, c é um papel, e c inere em b no tempo t. O papel c não é essencial para a existência física de b, mas define um contexto ou comportamento que b pode manifestar.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation between an independent continuant (the bearer) and a role specifically dependent on it.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação entre um continuante independente (o portador) e um papel (role) especificamente dependente dele.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Has Role</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Possui Papel</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_specification -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#has_specification">
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#bibliographic_record"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <skos:prefLabel xml:lang="en-us">Has specification</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Tem especificação</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#is_about -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#is_about">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000112 xml:lang="pt-br">este log de registro de empréstimo é_sobre o exemplar do livro físico e é_sobre João o leitor.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">this loan record log is_about the physical book copy and is_about Joao the reader.</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="en-us">A mapping derived from the Information Artifact Ontology (IAO) stating that an informational text or artifact points to, or registers information regarding, a concrete entity.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="pt-br">Um mapeamento derivado da Information Artifact Ontology (IAO) estabelecendo que um texto ou artefato informacional aponta para, ou registra informações a respeito de, uma entidade concreta.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation between an information content entity (like a log record) and the real-world independent continuant it references or reports.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação entre uma entidade de conteúdo informacional (como um registro de log) e o continuante independente do mundo real que ela referencia ou relata.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Is about</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">É sobre</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#is_concretized_in -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#is_concretized_in">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000600 xml:lang="en-us">According to BFO, information entities have no mass or space extension; they require a material carrier to be hosted. This relation maps that ontological hosting dependency.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation between a generically dependent continuant (Information Entity) and the material entity that serves as its hardware or physical carrier.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação entre um continuante genericamente dependente (Entidade de Informação) e a entidade material que serve como seu hardware ou suporte físico.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Is concretized in</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">É concretizado em</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#is_exemplified_by -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#is_exemplified_by">
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#bibliographic_manifestation"/>
        <rdfs:range rdf:resource="http://purl.org/marc-21/ontology#bibliographic_item"/>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#is_expression_of -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#is_expression_of">
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#bibliographic_expression"/>
        <rdfs:range rdf:resource="http://purl.org/marc-21/ontology#bibliographic_work"/>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#modifies -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#modifies">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <obo:IAO_0000112 xml:lang="en-us">A loan process modifies the availability of a bibliographic item.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="pt-br">Um processo de empréstimo modifica a disponibilidade de um exemplar bibliográfico.</obo:IAO_0000112>
        <rdfs:comment xml:lang="pt-br">Esta propriedade é usada em sentido amplo de engenharia para representar que um processo altera algum aspecto de um continuante.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">This property is used in a broad engineering sense to represent that a process changes some aspect of a continuant.</rdfs:comment>
        <skos:definition xml:lang="pt-br">Relaciona um processo a um continuante cujo estado, conteúdo informacional, papel, qualidade ou especificação é alterado durante o processo.</skos:definition>
        <skos:definition xml:lang="en-us">Relates a process to a continuant whose state, informational content, role, quality, or specification is changed during the process.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Modifica</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Modifies</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#owned_by -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#owned_by">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000112 xml:lang="pt-br">este exemplar de livro físico 4567 é propriedade_de a Biblioteca Municipal.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">this physical copy book 4567 is owned_by the City Library.</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="pt-br">Mapeia a guarda física e jurídica do mundo real. Uma entidade material independente é propriedade de uma organização social independente.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="en-us">Maps real-world physical and legal guardianship. An independent material entity is property of an independent social organization.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation connecting a physical material object (Item) to the library organization that possesses asset guardianship over it.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação conectando um objeto material físico (Item) à organização do tipo biblioteca que possui a guarda patrimonial sobre ele.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Adquirido por</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Owned by</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#performed_by -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#performed_by">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#published_by -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#published_by">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000112 xml:lang="pt-br">esta manifestação de 1899 foi publicada_por Editora Garnier.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">this 1899 manifestation was published_by Garnier Publisher.</obo:IAO_0000112>
        <obo:IAO_0000600 xml:lang="en-us">Binds a publication line to an institutional corporate body that has the legal and operational infrastructure to issue materials.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="pt-br">Vincula uma linha de publicação a um corpo corporativo institucional que possui a infraestrutura jurídica e operacional para emitir materiais.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A relation connecting an informational publication plan (Manifestation) to the organization responsible for its commercial manufacturing and distribution.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma relação conectando um plano informacional de publicação (Manifestação) à organização responsável por sua manufatura comercial e distribuição.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Publicado por</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Published by</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#represents_work -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#represents_work">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <obo:IAO_0000600 xml:lang="en-us">Allows query search systems to know which core abstract creation a specific record points to, bypassing the expression/manifestation layer for analytical retrieval.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="en-us">MARC 21 record 123 represents_work the abstract work of Dom Casmurro.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="pt-br">Permite que os sistemas de busca saibam para qual criação abstrata central um registro específico aponta, ignorando as camadas de expressão/manifestação para fins de recuperação analítica.</obo:IAO_0000600>
        <obo:IAO_0000600 xml:lang="pt-br">o registro MARC 21 123 representa_obra a obra abstrata de Dom Casmurro.</obo:IAO_0000600>
        <skos:definition xml:lang="en-us">A shortcut or direct relation linking a metadata string (Bibliographic Record) to the abstract creation (Work) it is intellectually associated with.</skos:definition>
        <skos:definition xml:lang="pt-br">Um atalho ou relação direta vinculando uma cadeia de metadados (Registro Bibliográfico) à criação abstrata (Obra) com a qual está intelectualmente associada.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Representa Obra</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Represents Work</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://purl.org/marc-21/ontology#updates -->

    <owl:ObjectProperty rdf:about="http://purl.org/marc-21/ontology#updates">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/marc-21/ontology#has_isbn -->

    <owl:DatatypeProperty rdf:about="http://purl.org/marc-21/ontology#has_isbn">
        <rdfs:comment xml:lang="en-us">Has ISBN</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Tem ISBN</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_isil -->

    <owl:DatatypeProperty rdf:about="http://purl.org/marc-21/ontology#has_isil">
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#library"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en-us">Has ISIL</rdfs:label>
        <rdfs:label xml:lang="pt-br">Possui ISIL</rdfs:label>
        <skos:definition xml:lang="en-us">Links a library organization to its normative International Standard Identifier for Libraries (ISO 15511).</skos:definition>
        <skos:definition xml:lang="pt-br">Vincula uma organização do tipo biblioteca ao seu identificador normativo internacional ISIL (ISO 15511).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_isni -->

    <owl:DatatypeProperty rdf:about="http://purl.org/marc-21/ontology#has_isni">
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#publisher"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en-us">Has ISNI</rdfs:label>
        <rdfs:label xml:lang="pt-br">Possui ISNI</rdfs:label>
        <skos:definition xml:lang="en-us">Links a publishing organization to its normative International Standard Name Identifier (ISO 27729).</skos:definition>
        <skos:definition xml:lang="pt-br">Vincula uma organização editorial ao seu identificador normativo internacional ISNI (ISO 27729).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- http://purl.org/marc-21/ontology#has_title -->

    <owl:DatatypeProperty rdf:about="http://purl.org/marc-21/ontology#has_title">
        <rdfs:domain rdf:resource="http://purl.org/marc-21/ontology#bibliographic_manifestation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/IAO_0000442 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000442">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </rdf:Description>
    


    <!-- http://purl.org/marc-21/ontology#bibliographic_expression -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#bibliographic_expression">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en-us">Bibliographic Expression</rdfs:label>
        <rdfs:label xml:lang="pt-br">Expressão Bibliográfica</rdfs:label>
        <skos:definition xml:lang="pt-br">A realização intelectual ou artística específica de uma obra sob a forma de notação alfa-numérica, linguística ou textual (ex: o texto original de Dom Casmurro em português).</skos:definition>
        <skos:definition xml:lang="en-us">The specific intellectual or artistic realization of a work in the form of alpha-numeric, musical, or choreographic notation (e.g., the original Dom Casmurro in Portuguese text).</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#bibliographic_item -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#bibliographic_item">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_isbn"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en-us">Bibliographic Item</rdfs:label>
        <rdfs:label xml:lang="pt-br">Item Bibliográfico</rdfs:label>
        <skos:definition xml:lang="en-us">It is a physical, tangible, and individualized object that you can hold in your hands. It has mass, three-dimensional extension, and defined macroscopic physical boundaries in the real world.</skos:definition>
        <skos:definition xml:lang="pt-br">É o objeto físico, tangível e individualizado que você consegue segurar com as mãos. Possui massa, extensão tridimensional e limites físicos macroscópicos definidos no mundo real.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#bibliographic_manifestation -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#bibliographic_manifestation">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en-us">Bibliographic Manifestation</rdfs:label>
        <rdfs:label xml:lang="pt-br">Manifestação Bibliográfica</rdfs:label>
        <skos:definition xml:lang="en-us">In the international normative standard (IFLA LRM), a Manifestation represents the ideal set of attributes of a mass-production publishing line (a model that defines the ISBN, the theoretical dimensions, and the publisher). It is not an individualized &quot;document&quot; that you read, but the conceptual recipe that the physical items follow. Therefore, preserving the conceptual purity of the MARC 21/LRM standard, it is the physical or digital embodiment of an expression, representing the product of a publishing line (it carries ideal attributes such as ISBN and publication data).</skos:definition>
        <skos:definition xml:lang="pt-br">No padrão normativo internacional (IFLA LRM), uma Manifestação representa o conjunto ideal de atributos de uma linha de produção editorial em massa (um modelo que define o ISBN, as dimensões teóricas e a editora). Ela não é um &quot;documento&quot; individualizado que você lê, mas a receita conceitual que os itens físicos seguem. Portanto preservando a pureza conceitual do padrão MARC 21/LRM, é a corporificação física ou digital de uma expressão, representando o produto de uma linha de produção editorial (carrega atributos ideais como ISBN e dados de publicação).</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#bibliographic_record -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#bibliographic_record">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#catalog"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en-us">Bibliographic Record</rdfs:label>
        <rdfs:label xml:lang="pt-br">Registro Bibliográfico</rdfs:label>
        <skos:definition xml:lang="en-us">A strictly encoded MARC 21 record. These are not free narrative documents, but structured strings that carry information, designed to logically encode, describe, and represent a manifestation.</skos:definition>
        <skos:definition xml:lang="pt-br">Um registro MARC 21 textualmente codificado de forma estrita. Não são documentos narrativos livres, mas strings estruturadas que carregam informação, projetada para codificar logicamente, descrever e representar uma manifestação.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#bibliographic_work -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#bibliographic_work">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:label xml:lang="en-us">Bibliographic Work</rdfs:label>
        <rdfs:label xml:lang="pt-br">Obra Bibliográfica</rdfs:label>
        <skos:definition xml:lang="en-us">A distinct intellectual or artistic creation (abstract core, e.g., the story of Dom Casmurro) that generically depends on expressions to exist in the universe.
A Work is the most abstract level of intellectual creation (the idea of ​​the story). If you translate Dom Casmurro into English, into French, or turn it into a play, the Work remains rigorously the same, although the texts (the expressions) have changed completely. The Work itself does not have fixed text characters in a language; it transcends language.</skos:definition>
        <skos:definition xml:lang="pt-br">Uma criação intelectual ou artística distinta (núcleo abstrato, ex: a história de Dom Casmurro) que depende genericamente de expressões para existir no universo.
Uma Obra é o nível mais abstrato da criação intelectual (a ideia da história). Se você traduzir Dom Casmurro para o Inglês, para o Francês ou transformá-lo em uma peça de teatro, a Obra continua sendo rigorosamente a mesma, embora os textos (as expressões) tenham mudado completamente. A Obra em si não possui caracteres de texto fixados em um idioma; ela transcende a linguagem.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#catalog -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#catalog">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0001000"/>
        <rdfs:label xml:lang="en-us">Bibliographic Catalog</rdfs:label>
        <rdfs:label xml:lang="pt-br">Catálogo Bibliográfico</rdfs:label>
        <skos:definition xml:lang="en-us">An informational collection composed of structured bibliographic records organized according to cataloging rules, concretized within a catalog carrier. It is not a textbook, it is a logical and aggregated collection of individual records for inventory and search purposes, of a computational and asset-related nature.</skos:definition>
        <skos:definition xml:lang="pt-br">Entidade informacional composta por registros bibliográficos estruturados e organizados segundo regras catalográficas, concretizada em um ou mais suportes materiais (catalog_carrier). Não é um livro texto, é uma coleção lógica e agregada de registros individuais com o propósito de inventário e busca, de natureza computacional e patrimonial.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#catalog_carrier -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#catalog_carrier">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en-us">Catalog Carrier</rdfs:label>
        <rdfs:label xml:lang="pt-br">Suporte do Catálogo</rdfs:label>
        <skos:definition xml:lang="pt-br">Dispositivo físico onde reside o arquivo informacional digital (servidor/disco rígido).</skos:definition>
        <skos:definition xml:lang="en-us">Physical device where the digital information file resides (server/hard drive).</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#cataloger_role -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#cataloger_role">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="pt-br">O papel técnico que a profissional Maria desempenha no sistema enquanto realiza o tratamento de dados lógicos no formato MARC 21.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">The technical role that Maria plays in the system while processing logical data in MARC 21 format.</obo:IAO_0000112>
        <rdfs:comment xml:lang="pt-br">As funções operacionais de catalogação dependem de um vínculo externo (contrato, designação institucional ou turno de trabalho), cessando as suas prerrogativas quando esse contexto deixa de existir.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">The operational functions of cataloging depend on an external link (contract, institutional designation, or work shift), ceasing its prerogatives when that context no longer exists.</rdfs:comment>
        <skos:definition xml:lang="en-us">A functional and temporary role inhering in a person within an institutional context, authorizing them to perform technical processing and metadata creation.</skos:definition>
        <skos:definition xml:lang="pt-br">É o papel funcional e temporário que inere em uma pessoa dentro de um contexto institucional, autorizando-a a realizar o processamento técnico e a criação de metadados.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Cataloger Role</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Papel de Catalogador</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#cataloging_process -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#cataloging_process">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000572"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_input"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#bibliographic_manifestation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_output"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#bibliographic_record"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_participant"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#modifies"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#cataloging_status_specification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="pt-br">Maria cataloga a manifestação Garnier de 1899 de Dom Casmurro e cria um registro bibliográfico MARC 21.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">Maria catalogs the Garnier 1899 manifestation of Dom Casmurro and creates a MARC 21 bibliographic record.</obo:IAO_0000112>
        <rdfs:comment xml:lang="en-us">Cataloging processes transform knowledge about a manifestation into structured metadata represented in bibliographic records.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Processos de catalogação transformam conhecimento sobre uma manifestação em metadados estruturados representados em registros bibliográficos.</rdfs:comment>
        <skos:definition xml:lang="en-us">A documenting process in which a bibliographic manifestation is analyzed and described through the creation or modification of a bibliographic record.</skos:definition>
        <skos:definition xml:lang="pt-br">Processo de documentação no qual uma manifestação bibliográfica é analisada e descrita por meio da criação ou modificação de um registro bibliográfico.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Cataloging Process</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Processo de Catalogação</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#cataloging_status_specification -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#cataloging_status_specification">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <skos:definition xml:lang="en-us">An informational specification metadata entity that declares and tracks the technical processing phase or workflow stage of a BibliographicRecord over time (In preparation, Cataloged, or Reviewed) within the library system.</skos:definition>
        <skos:definition xml:lang="pt-br">É a entidade de especificação informacional (metadado) que declara e rastreia a fase de tratamento técnico ou workflow em que um BibliographicRecord se encontra no tempo (Em elaboração, Catalogado ou Revisado) dentro do sistema da biblioteca.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Cataloging Status Specification</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Especificação de Status de Catalogação</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#item_availability -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#item_availability">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <obo:IAO_0000112 xml:lang="pt-br">O exemplar tombamento 12345 encontra-se disponível para empréstimo.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">The book copy Tomb Number 12345 is currently available for loan.</obo:IAO_0000112>
        <rdfs:comment xml:lang="pt-br">A disponibilidade de um exemplar pode variar ao longo do tempo em decorrência de processos de circulação como empréstimos, devoluções, reservas ou extravios.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">The availability of a bibliographic item may change over time as a consequence of circulation processes such as loans, returns, reservations, or losses.</rdfs:comment>
        <skos:definition xml:lang="en-us">A relational quality that inheres in a bibliographic item and reflects its current accessibility status within a library circulation context.</skos:definition>
        <skos:definition xml:lang="pt-br">Qualidade relacional que inere em um exemplar bibliográfico e reflete sua condição atual de acessibilidade no contexto de circulação de uma biblioteca.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Disponibilidade do Exemplar</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Item Availability</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#library -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#library">
        <rdfs:subClassOf rdf:resource="http://purl.org/marc-21/ontology#organization"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_isil"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">Biblioteca</rdfs:label>
        <rdfs:label xml:lang="en-us">Library</rdfs:label>
        <skos:definition xml:lang="en-us">A physical institution responsible for the custody, processing, and dissemination of bibliographic collections.</skos:definition>
        <skos:definition xml:lang="pt-br">Instituição material responsável pela custódia, processamento e disseminação do acervo bibliográfico.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#loan_process -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#loan_process">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000035"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_input"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#bibliographic_item"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_input"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_input"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#reader_role"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_output"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#loan_record"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#modifies"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#item_availability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="en-us">John  borrows a physical copy of Dom Casmurro from the Municipal Library.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="pt-br">João empresta um exemplar físico de Dom Casmurro da Biblioteca Municipal.</obo:IAO_0000112>
        <rdfs:comment xml:lang="en-us">Loan processes modify the circulation status of bibliographic items and generate documentary evidence of the transaction.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Processos de empréstimo modificam o estado de circulação dos exemplares bibliográficos e geram evidências documentais da transação.</rdfs:comment>
        <skos:definition xml:lang="en-us">A planned process in which a bibliographic item is temporarily assigned by a library to a reader and documented through a loan record.</skos:definition>
        <skos:definition xml:lang="pt-br">Processo planejado no qual um exemplar bibliográfico é temporariamente atribuído por uma biblioteca a um leitor e documentado por meio de um registro de empréstimo.</skos:definition>
        <skos:prefLabel xml:lang="en-us">Loan Process</skos:prefLabel>
        <skos:prefLabel xml:lang="pt-br">Processo de Empréstimo</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#loan_record -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#loan_record">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#catalog"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en-us">Loan Record</rdfs:label>
        <rdfs:label xml:lang="pt-br">Registro de Empréstimo</rdfs:label>
        <skos:definition xml:lang="en-us">A MARC 21 record that has been textually modified in written form. It is not a free narrative document, but rather structured strings that carry information. An informational piece of log data or transaction record that permanently attests the historical loan transaction between a reader and an item.</skos:definition>
        <skos:definition xml:lang="pt-br">Um registro MARC 21 textualmente modificado de forma escrita. Não é documento narrativo livre, mas strings estruturadas que carregam informação. Um artefato informacional ou linha de log que atesta permanentemente a transação histórica de empréstimo ocorrida entre um leitor e um item.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#organization -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#organization">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#person -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#person">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en-us">Person</rdfs:label>
        <rdfs:label xml:lang="pt-br">Pessoa</rdfs:label>
        <skos:definition xml:lang="en-us">A biological and real human individual. A concrete being that exists in time and retains its own identity over time while undergoing changes.</skos:definition>
        <skos:definition xml:lang="pt-br">É o indivíduo humano biológico e real. O ser concreto que existe no tempo que retém sua identidade própria ao longo do tempo enquanto passa por mudanças.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#publisher -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#publisher">
        <rdfs:subClassOf rdf:resource="http://purl.org/marc-21/ontology#organization"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_isni"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">Editora</rdfs:label>
        <rdfs:label xml:lang="en-us">Publisher</rdfs:label>
        <skos:definition xml:lang="en-us">A company or publishing entity responsible for the financing, production, and commercial distribution of publications.</skos:definition>
        <skos:definition xml:lang="pt-br">Empresa ou entidade editorial responsável pelo financiamento, produção e distribuição comercial de publicações.</skos:definition>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#reader_role -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#reader_role">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#person"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="pt-br">O papel de usuário que passa a inerar em João assim que o seu cadastro administrativo na instituição é validado.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">The user role that begins to inherit for João is activated as soon as his administrative registration with the institution is validated.</obo:IAO_0000112>
        <rdfs:comment xml:lang="pt-br">A condição de usuário/leitor é ativada por um evento externo (o cadastro/emissão da carteirinha), conferindo direitos e deveres específicos de acesso ao acervo material.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">The user/reader status is activated by an external event (registration/issuance of the membership card), granting specific rights and responsibilities for accessing the material collection.</rdfs:comment>
        <skos:definition xml:lang="en-us">A social and legal role assumed by a person when they establish a formal administrative relationship with a library to consume and borrow items.</skos:definition>
        <skos:definition xml:lang="pt-br">É o papel social e jurídico assumido por uma pessoa quando ela estabelece uma relação administrativa formal com uma biblioteca para consumir e tomar itens por empréstimo.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Papel de Leitor</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Reader Role</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#record_completeness_specification -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#record_completeness_specification">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000030"/>
        <skos:definition xml:lang="en-us">An informational specification entity (metadata) associated with a BibliographicRecord that indicates its structural enrichment and data density level (e.g., Complete if it contains all mandatory tags, or Partial if it is a preliminary draft), objectively evaluated based on MARC 21 standard rules.</skos:definition>
        <skos:definition xml:lang="pt-br">É a entidade de especificação informacional (metadado) associada a um BibliographicRecord que indica o seu nível de detalhamento e preenchimento estrutural (ex: Completo se contiver todas as tags obrigatórias, ou Parcial se for um rascunho preliminar), avaliada objetivamente com base nas regras normativas do formato MARC 21.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Especificação de Completude do Registro</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Record Completeness Specification</skos:prefLabel>
    </owl:Class>
    


    <!-- http://purl.org/marc-21/ontology#record_update_process -->

    <owl:Class rdf:about="http://purl.org/marc-21/ontology#record_update_process">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000572"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_input"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#bibliographic_record"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#has_output"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#bibliographic_record"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/marc-21/ontology#modifies"/>
                <owl:someValuesFrom rdf:resource="http://purl.org/marc-21/ontology#bibliographic_record"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112 xml:lang="en-us">A cataloger updates a MARC 21 record by adding missing subject headings.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="pt-br">Um catalogador atualiza um registro MARC 21 adicionando assuntos que estavam ausentes.</obo:IAO_0000112>
        <rdfs:comment xml:lang="pt-br">Processos de atualização preservam a identidade do registro bibliográfico enquanto alteram seu conteúdo informacional.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">Record update processes preserve the identity of the bibliographic record while changing its informational content.</rdfs:comment>
        <skos:definition xml:lang="en-us">A documenting process in which an existing bibliographic record is revised, corrected, enriched, or otherwise modified.</skos:definition>
        <skos:definition xml:lang="pt-br">Processo de documentação no qual um registro bibliográfico existente é revisado, corrigido, enriquecido ou modificado.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Processo de Atualização de Registro</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Record Update Process</skos:prefLabel>
    </owl:Class>
    


