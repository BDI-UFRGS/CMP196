        <embodies rdf:resource="http://purl.org/marc-21/ontology#inst_portuguese_original_expression"/>
        <published_by rdf:resource="http://purl.org/marc-21/ontology#inst_Garnier_Publisher"/>
        <rdfs:label xml:lang="pt-br">Edição Garnier de 1899</rdfs:label>
        <rdfs:label xml:lang="en-us">Garnier 1899 Edition</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_library_main_catalog -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_library_main_catalog">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#catalog"/>
        <is_concretized_in rdf:resource="http://purl.org/marc-21/ontology#inst_Local_HD_Server"/>
        <rdfs:label xml:lang="pt-br">Catálogo Principal da Biblioteca</rdfs:label>
        <rdfs:label xml:lang="en-us">Library Main Catalog</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_loan_process_001 -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_loan_process_001">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#loan_process"/>
        <has_input rdf:resource="http://purl.org/marc-21/ontology#inst_Dom_Casmurro_1899_Paper_Book"/>
        <has_output rdf:resource="http://purl.org/marc-21/ontology#inst_loan_record_001"/>
        <has_participant rdf:resource="http://purl.org/marc-21/ontology#inst_John_Reader"/>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_loan_record_001 -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_loan_record_001">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#loan_record"/>
        <obo:BFO_0000050 rdf:resource="http://purl.org/marc-21/ontology#inst_library_main_catalog"/>
        <is_about rdf:resource="http://purl.org/marc-21/ontology#inst_Dom_Casmurro_1899_Paper_Book"/>
        <is_about rdf:resource="http://purl.org/marc-21/ontology#inst_John_Reader"/>
        <rdfs:comment xml:lang="pt-br">Empréstimo feito por Maria de item da edição Garnier para João.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">Maria loaned an item from the Garnier edition to John.</rdfs:comment>
        <rdfs:label xml:lang="en-us">Loan Transaction Record 001</rdfs:label>
        <rdfs:label xml:lang="pt-br">Registro de Transação de Empréstimo 001</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_loaned -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_loaned">
        <rdf:type rdf:resource="http://purl.org/marc-21/ontology#item_availability"/>
        <obo:IAO_0000112 xml:lang="pt-br">O exemplar tombamento 12345 está emprestado para João.</obo:IAO_0000112>
        <obo:IAO_0000112 xml:lang="en-us">The copy Tomb Number 12345 is loaned to John.</obo:IAO_0000112>
        <skos:definition xml:lang="en-us">An item availability state indicating that a bibliographic item is temporarily assigned to a reader through a loan process.</skos:definition>
        <skos:definition xml:lang="pt-br">Estado de disponibilidade indicando que um exemplar bibliográfico está temporariamente associado a um leitor por meio de um processo de empréstimo.</skos:definition>
        <skos:prefLabel xml:lang="pt-br">Emprestado</skos:prefLabel>
        <skos:prefLabel xml:lang="en-us">Loaned</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_marc21_rec_123 -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_marc21_rec_123">
