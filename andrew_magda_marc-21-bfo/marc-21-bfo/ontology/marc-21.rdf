        <rdfs:comment xml:lang="en-us">The physical institution responsible for holding the collection.</rdfs:comment>
        <rdfs:label xml:lang="pt-br">Biblioteca Municipal</rdfs:label>
        <rdfs:label xml:lang="en-us">City Library</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_Dom_Casmurro_1899_Paper_Book -->

