        <rdfs:comment xml:lang="pt-br">A tradicional casa editorial estabelecida no Rio de Janeiro.</rdfs:comment>
        <rdfs:comment xml:lang="en-us">The traditional publishing house established in Rio de Janeiro.</rdfs:comment>
        <rdfs:label xml:lang="en-us">Livraria Garnier</rdfs:label>
        <rdfs:label xml:lang="pt-br">Livraria Garnier</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://purl.org/marc-21/ontology#inst_John_Reader -->

    <owl:NamedIndividual rdf:about="http://purl.org/marc-21/ontology#inst_John_Reader">
