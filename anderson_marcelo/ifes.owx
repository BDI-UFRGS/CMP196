    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>obo:IAO_0000429</AbbreviatedIRI>
        <Literal>Lista de endereços de e-mail nos quais as mensagens de e-mail podem ser recebidas</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00001</IRI>
        <Literal xml:lang="pt-br">Define todos os atores ou agentes humanos envolvidos em um projeto durante todo o seu ciclo de vida, facilitando o uso de definições de pessoas e organizações na parte de recursos do modelo de objeto</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00001</IRI>
        <Literal xml:lang="en">Defines all human actors or agents involved in a project throughout its lifecycle, facilitating the use of person and organization definitions within the resources section of the object model</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000119"/>
        <IRI>IFES_00001</IRI>
        <Literal>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcActor</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>IFES_00001</IRI>
        <Literal xml:lang="en">actor</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>IFES_00001</IRI>
        <Literal xml:lang="pt-br">ator</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:example"/>
        <IRI>IFES_00001</IRI>
        <Literal>Inclui nome, endereço, endereços de telecomunicações e funções</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00002</IRI>
        <Literal xml:lang="pt-br">O estado geral de um produto baseado na avaliação da contribuição de cada critério para esse estado geral, onde os valores atribuídos ao estado avaliado devem ser acordados e documentados por meio de normas locais</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00002</IRI>
        <Literal xml:lang="en">The overall state of a product based on the assessment of each criterion&apos;s contribution to that overall state, where the values ​​assigned to the assessed state must be agreed upon and documented in accordance with local standards</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000119"/>
        <IRI>IFES_00002</IRI>
        <Literal>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentCondition</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>IFES_00002</IRI>
        <Literal xml:lang="en">assessment condition</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>IFES_00002</IRI>
        <Literal xml:lang="pt-br">condição de avaliação</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="skos:example"/>
        <IRI>IFES_00002</IRI>
        <Literal>Valor medido numa escala de 1 a 10 ou por meio de denominações como Bom, Regular e Ruim</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000112"/>
        <IRI>IFES_00003</IRI>
        <Literal>O edifício corporativo é uma estrutura que oferece abrigo aos funcionários</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00003</IRI>
        <Literal xml:lang="en">It represents a structure that provides shelter for its occupants or contents and is located at a single site. The building also serves as a basic element in the spatial structure hierarchy of a construction project&apos;s components (along with the site, the floor, and the space)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00003</IRI>
        <Literal xml:lang="pt-br">Representa uma estrutura que oferece abrigo aos seus ocupantes ou ao seu conteúdo e que se encontra em um único local. O edifício também serve como elemento básico na hierarquia da estrutura espacial dos componentes de um projeto de construção (juntamente com o terreno, o pavimento e o espaço)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000119"/>
