        <IRI>IFES_00062</IRI>
        <Literal xml:lang="pt-br">Sistema utilizado para distribuição de fluxo</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00062</IRI>
        <Literal xml:lang="en">System used for flow distribution</Literal>
    </AnnotationAssertion>
