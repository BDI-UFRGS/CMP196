        <IRI>IFES_00061</IRI>
        <Literal xml:lang="en">stair</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:subClassOf"/>
        <IRI>IFES_00061</IRI>
        <Literal></Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
