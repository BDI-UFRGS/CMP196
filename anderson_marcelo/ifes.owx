        <AnnotationProperty abbreviatedIRI="obo:IAO_0000112"/>
        <IRI>IFES_00042</IRI>
        <Literal>Sistemas relacionados a serviços prediais, como o sistema de tubulação, o sistema de água fria, etc</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00042</IRI>
        <Literal xml:lang="en">A system is an organized combination of related parts within an AEC product, assembled for a common purpose or function or to provide a service. A system is essentially an aggregation of functionally related products</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00042</IRI>
        <Literal xml:lang="pt-br">Um sistema é uma combinação organizada de partes relacionadas dentro de um produto AEC, composta para um propósito ou função comum ou para fornecer um serviço. Um sistema é essencialmente uma agregação de produtos funcionalmente relacionados</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
