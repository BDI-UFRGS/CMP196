    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000112"/>
        <IRI>IFES_00038</IRI>
        <Literal>O terreno é uma área delimitada para a construção de um novo hospital.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00038</IRI>
        <Literal xml:lang="en">A site is a defined area of ​​intervention—potentially with available water—where the construction project will be carried out. A site may be used for the construction, renovation, or demolition of a building or buildings, or for other construction-related undertakings.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00038</IRI>
        <Literal xml:lang="pt-br">Um terreno é uma área de intervenção definida, com possível disponibilidade de água, na qual a construção do projeto será concluída. Um terreno pode ser usado para construir, reformar ou demolir edifício(s), ou para outros empreendimentos relacionados à construção</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000119"/>
        <IRI>IFES_00038</IRI>
        <Literal>https://search.bsdd.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcSite</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>IFES_00038</IRI>
        <Literal xml:lang="en">ifes site</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>IFES_00038</IRI>
        <Literal xml:lang="pt-br">terreno da ifes</Literal>
    </AnnotationAssertion>
