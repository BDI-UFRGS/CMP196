        <AnnotationProperty abbreviatedIRI="obo:IAO_0000112"/>
        <IRI>IFES_00129</IRI>
        <Literal>O sistema de climatização central é uma instalação de ar condicionado projetada para fornecer conforto térmico e controlar contaminantes por meio de refrigeração e filtragem</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00129</IRI>
        <Literal xml:lang="en">Heating, ventilation, and air conditioning systems capable of regulating temperature, humidity, and indoor air quality, designed to provide thermal comfort and control airborne contaminants through heating, cooling, ventilation, filtration, and humidity control</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000115"/>
        <IRI>IFES_00129</IRI>
        <Literal xml:lang="pt-br">Sistemas de aquecimento , ventilação e ar condicionado com a capacidade de regular a temperatura , a umidade e a qualidade do ar interno sendo projetados para proporcionar conforto térmico e controlar contaminantes presentes no ar por meio de aquecimento, resfriamento, ventilação, filtragem e controle de umidade</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="obo:IAO_0000119"/>
