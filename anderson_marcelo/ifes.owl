                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00103"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Device that is used to dissipate heat, typically by condensing a substance such as a refrigerant from its gaseous to its liquid state</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo usado para dissipar calor, geralmente condensando uma substância, como um refrigerante, do estado gasoso para o estado líquido</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCondenser.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">condensador</rdfs:label>
        <rdfs:label xml:lang="en">condenser</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00098 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00098">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Device typically used to cool air by circulating a fluid such as chilled water through exposed finned tubes above a space</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo normalmente usado para resfriar o ar através da circulação de um fluido, como água gelada, por tubos aletados expostos acima de um ambiente</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCooledBeam.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">cooled beam</rdfs:label>
        <rdfs:label xml:lang="pt-br">viga fria</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00099 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00099">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Device which rejects heat to ambient air by circulating a fluid such as water through it to reduce its temperature by partial evaporation</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo que rejeita calor para o ar ambiente através da circulação de um fluido, como água, que reduz sua temperatura por evaporação parcial</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCoolingTower.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">cooling tower</rdfs:label>
        <rdfs:label xml:lang="pt-br">torre de resfriamento</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00100 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00100">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00185"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00097"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>O compressor hermético é um dispositivo que comprime um fluido refrigerante para circulação forçada no circuito de refrigeração</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Device that compresses a fluid typically used in a refrigeration circuit</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo que comprime um fluido, normalmente usado em um circuito de refrigeração</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCompressor.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">compressor</rdfs:label>
        <rdfs:label xml:lang="pt-br">compressor</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00101 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00101">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Device that cools air by saturating it with water vapor</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo que resfria o ar saturando-o com vapor de água</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcEvaporativeCooler.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">evaporative cooler</rdfs:label>
        <rdfs:label xml:lang="pt-br">resfriador</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00102 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00102">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00182"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
