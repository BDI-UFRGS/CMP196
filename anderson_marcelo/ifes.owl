        <obo:IAO_0000115 xml:lang="en"></obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br"></obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcFlowController.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">controlador de sistema de distribuição</rdfs:label>
