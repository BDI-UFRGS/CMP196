        <rdfs:label xml:lang="en">task status</rdfs:label>
        <skos:example>O status da tareda pode ser classificado com concluído/em obra, atrasado/não atrasado, dentre outras classificações por meio de normas locais</skos:example>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00049 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00049">
