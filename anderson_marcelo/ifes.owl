        <obo:IAO_0000115 xml:lang="en">External physical documents related to the elements that make up a building, required for maintenance</obo:IAO_0000115>
        <obo:IAO_0000119>https://ifc43-docs.standards.buildingsmart.org/IFC/RELEASE/IFC4x3/HTML/lexical/IfcDocumentInformation.htm</obo:IAO_0000119>
