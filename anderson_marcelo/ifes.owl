    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/IAO_0000310 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000310">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty>
                    <rdf:Description>
                        <inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                    </rdf:Description>
                </onProperty>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00020"/>
            </Restriction>
        </rdfs:subClassOf>
    </rdf:Description>
    


    <!-- http://purl.obolibrary.org/obo/IAO_0000429 -->

    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/IAO_0000429">
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00018"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Lista de endereços de e-mail nos quais as mensagens de e-mail podem ser recebidas</rdfs:comment>
    </rdf:Description>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00001 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000023"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00033"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="pt-br">Define todos os atores ou agentes humanos envolvidos em um projeto durante todo o seu ciclo de vida, facilitando o uso de definições de pessoas e organizações na parte de recursos do modelo de objeto</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Defines all human actors or agents involved in a project throughout its lifecycle, facilitating the use of person and organization definitions within the resources section of the object model</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcActor</obo:IAO_0000119>
        <rdfs:label xml:lang="en">actor</rdfs:label>
        <rdfs:label xml:lang="pt-br">ator</rdfs:label>
        <skos:example>Inclui nome, endereço, endereços de telecomunicações e funções</skos:example>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00002 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00022"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="pt-br">O estado geral de um produto baseado na avaliação da contribuição de cada critério para esse estado geral, onde os valores atribuídos ao estado avaliado devem ser acordados e documentados por meio de normas locais</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">The overall state of a product based on the assessment of each criterion&apos;s contribution to that overall state, where the values ​​assigned to the assessed state must be agreed upon and documented in accordance with local standards</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/AssessmentCondition</obo:IAO_0000119>
        <rdfs:label xml:lang="en">assessment condition</rdfs:label>
        <rdfs:label xml:lang="pt-br">condição de avaliação</rdfs:label>
        <skos:example>Valor medido numa escala de 1 a 10 ou por meio de denominações como Bom, Regular e Ruim</skos:example>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00003 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00003">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00024"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00010"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty>
                    <rdf:Description>
                        <inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                    </rdf:Description>
                </onProperty>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00006"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>O edifício corporativo é uma estrutura que oferece abrigo aos funcionários</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">It represents a structure that provides shelter for its occupants or contents and is located at a single site. The building also serves as a basic element in the spatial structure hierarchy of a construction project&apos;s components (along with the site, the floor, and the space)</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Representa uma estrutura que oferece abrigo aos seus ocupantes ou ao seu conteúdo e que se encontra em um único local. O edifício também serve como elemento básico na hierarquia da estrutura espacial dos componentes de um projeto de construção (juntamente com o terreno, o pavimento e o espaço)</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcBuilding</obo:IAO_0000119>
        <rdfs:label xml:lang="en">building</rdfs:label>
        <rdfs:label xml:lang="pt-br">edificação</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00004 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00004">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000178"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00003"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="pt-br">Tipo de obra realizada no imóvel, seja uma construção nova, renovação, remodelação, manutenção, etc</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Type of work performed on the property, whether a new construction, renovation, remodeling, maintenance, etc.</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/ConstructionMethod</obo:IAO_0000119>
        <rdfs:label xml:lang="en">building construction method</rdfs:label>
        <rdfs:label xml:lang="pt-br">método construtivo</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00005 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00005">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000300"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00003"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Description of the building where the element is located</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Descrição da edificação onde se encontra o elemento</obo:IAO_0000115>
        <obo:IAO_0000119>https://search.bsdd.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/Description</obo:IAO_0000119>
        <rdfs:label xml:lang="en">building description</rdfs:label>
        <rdfs:label xml:lang="pt-br">descrição da edificação</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00006 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00003"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Name of a structure that provides shelter to its occupants or contents and is located in a single place</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Nome de uma estrutura que oferece abrigo aos seus ocupantes ou ao seu conteúdo e que se encontra em um único local</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/Name</obo:IAO_0000119>
        <rdfs:label xml:lang="en">building name</rdfs:label>
        <rdfs:label xml:lang="pt-br">nome da edificação</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00007 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty>
                    <rdf:Description>
                        <inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                    </rdf:Description>
                </onProperty>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00009"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000171"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00010"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>A sala é um volume delimitado fisicamente para atividades de escritório.</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A space represents an area or volume—delimited either physically or theoretically—that serves specific functions within a building.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Um espaço representa uma área ou volume delimitado, real ou teoricamente, que proporcionam determinadas funções dentro de um edifício</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcSpace</obo:IAO_0000119>
        <rdfs:label xml:lang="en">building space</rdfs:label>
        <rdfs:label xml:lang="pt-br">espaço da edificação</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00008 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000300"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00007"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Description of the space where the element is located</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Descrição do espaço onde se encontra o elemento</obo:IAO_0000115>
        <obo:IAO_0000119>https://search.bsdd.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/Description</obo:IAO_0000119>
        <rdfs:label xml:lang="en">building space description</rdfs:label>
        <rdfs:label xml:lang="pt-br">descrição do espaço da edificação</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00009 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00009">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:subClassOf>
            <Restriction>
