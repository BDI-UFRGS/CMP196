            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>O manual de instruções é utilizado na isntalação de um ar condicionado</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Any system, infrastructure, or material that provides data, knowledge, or content to users</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Qualquer sistema, infraestrutura ou material que forneça dados, conhecimento ou conteúdo aos usuários</obo:IAO_0000115>
        <rdfs:label xml:lang="en">information resource</rdfs:label>
        <rdfs:label xml:lang="pt-br">recurso informacional</rdfs:label>
    </Class>
    


