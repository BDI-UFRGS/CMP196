                        </unionOf>
                    </Class>
                </someValuesFrom>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>Um filtro de ar é utilizado na substituição de outro avariado</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Ativo tangível ou substância física utilizada para produzir bens, prestar serviços ou concluir projetos</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Tangible asset or physical substance used to produce goods, provide services, or complete projects</obo:IAO_0000115>
        <rdfs:label xml:lang="en">material resource</rdfs:label>
        <rdfs:label xml:lang="pt-br">rercurso material</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00163 -->

