        <rdfs:label xml:lang="en">telephone number</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00050 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00050">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00022"/>
        <obo:IAO_0000112>Elementos construídos são: fachada cortina, portas e outros, no caso de edifícios; paredes, colunas, estacas e vigas</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Compreende todos os elementos que fazem parte essencial da construção de um edifício, ou seja, seu sistema estrutural e de separação de espaços</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Comprises all elements that are primarily part of the construction of a built facility, i.e., its structural and space separating system</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcBuiltElement.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">built element</rdfs:label>
        <rdfs:label xml:lang="pt-br">elemento construído</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00051 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00051">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00022"/>
        <obo:IAO_0000112>Ttubos e conexões que participam do sistema de abastecimento de água predial</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Generalization of all elements that participate in a distribution system</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Generalização de todos os elementos que participam de um sistema de distribuição</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcDistributionElement.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">distribution element</rdfs:label>
        <rdfs:label xml:lang="pt-br">elemento de distribuição</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00052 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00052">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>A parede que subdivide os dormitórios</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Representa uma construção vertical que pode delimitar ou subdividir espaços. As paredes são geralmente elementos planos verticais, ou quase verticais, frequentemente projetados para suportar cargas estruturais</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Represents a vertical construction that may bound or subdivide spaces. Wall are usually vertical, or nearly vertical, planar elements, often designed to bear structural loads</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcWall.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">parede</rdfs:label>
        <rdfs:label xml:lang="en">wall</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00053 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00053">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>A janela basculante é um elemento de construção que fornece luz natural e ventilação através de uma abertura vertical</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Building element that is predominately used to provide natural light and fresh air. It includes vertical opening but also horizontal opening such as skylights or light domes</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Elemento de construção usado principalmente para fornecer luz natural e ar fresco. Inclui aberturas verticais, mas também horizontais, como claraboias ou domos de luz</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcWindow.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">janela</rdfs:label>
        <rdfs:label xml:lang="en">window</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00054 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00054">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>A porta de correr é um elemento construído que fornece acesso controlado para pessoas e mercadorias</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Built element that is predominately used to provide controlled access for people, goods, animals and vehicles</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Elemento construído usado principalmente para controlar o acesso de pessoas, mercadorias, animais e veículos</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcDoor.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">door</rdfs:label>
        <rdfs:label xml:lang="pt-br">porta</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00055 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00055">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>A telha cerâmica é uma cobertura da parte superior do edifício que protege a edificação contra as ações da chuva</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Cobertura da parte superior de um edifício, protegendo-o dos efeitos das intempéries</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Covering of the top part of a building, it protects the building against the effects of weather</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcRoof.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">roof</rdfs:label>
        <rdfs:label xml:lang="pt-br">telhado</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00056 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00056">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>Coverings include wall claddings, floorings, suspended ceilings, moldings and skirting boards</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Element which covers some part of another element and is fully dependent on that other element</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Elemento que cobre parte de outro elemento e é totalmente dependente desse outro elemento</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCovering.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">covering</rdfs:label>
        <rdfs:label xml:lang="pt-br">revestimento</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00057 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00057">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>Elemento estrutural horizontal que resiste aos esforços de flexão da laje</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Elemento estrutural horizontal, ou quase horizontal, capaz de suportar carga principalmente resistindo à flexão</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Typically a horizontal, or nearly horizontal, structural member that is capable of withstanding load primarily by resisting bending</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcBeam.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">beam</rdfs:label>
        <rdfs:label xml:lang="pt-br">viga</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00058 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00058">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>A laje do terceiro andar é um componente da construção que delimita verticalmente o segundo e o terceito andar</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Component of the construction that may enclose a space vertically</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Componente da construção que pode delimitar um espaço verticalmente</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcSlab.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">laje</rdfs:label>
        <rdfs:label xml:lang="en">slab</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00059 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00059">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>Elemento estrutural vertical alinhado à interseção dos eixos A e 2 do projeto</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Elemento estrutural ou arquitetônico vertical que geralmente se alinha com a interseção de uma malha estrutural</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Vertical structural or architectural member which often is aligned with a structural grid intersection</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcColumn.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">column</rdfs:label>
        <rdfs:label xml:lang="pt-br">pilar</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00061 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00061">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00050"/>
        <obo:IAO_0000112>A escada interna é uma passagem vertical que permite aos ocupantes subir degraus do primeiro para o segundo pavimento e inclui um patamar intermediário</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Passagem vertical que permite aos ocupantes caminhar (subir degraus) de um nível de piso para outro em uma elevação diferente. Pode incluir um patamar como laje intermediária</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Passageway allowing occupants to walk (step) from one floor level to another floor level at a different elevation. It may include a landing as an intermediate floor slab</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcStair.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">escada</rdfs:label>
        <rdfs:label xml:lang="en">stair</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00062 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00062">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00051"/>
        <obo:IAO_0000115 xml:lang="pt-br">Sistema utilizado para distribuição de fluxo</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">System used for flow distribution</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcFlowSegment.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">flow segment</rdfs:label>
        <rdfs:label xml:lang="pt-br">segmento de sistema de distribuição</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00063 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00063">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00051"/>
        <obo:IAO_0000115 xml:lang="pt-br">Define a ocorrência de uma junção ou transição em um sistema de distribuição de fluxo, como um cotovelo ou uma conexão em T</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Defines the occurrence of a junction or transition in a flow distribution system, such as an elbow or tee</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcFlowFitting.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">conexão de sistema de distribuição</rdfs:label>
        <rdfs:label xml:lang="en">flow fitting</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00064 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00064">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00062"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000129"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00130"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>Fiação elétrica de cobre</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Flow segment used to carry electrical power, data, or telecommunications signals</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Segmento de fluxo usado para transportar energia elétrica, dados ou sinais de telecomunicações</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCableSegment.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">cable segment</rdfs:label>
        <rdfs:label xml:lang="pt-br">cabo</rdfs:label>
        <rdfs:subClassOf></rdfs:subClassOf>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00065 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00065">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00062"/>
        <obo:IAO_0000112>Eletrocalha</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Flow segment that is specifically used to carry and support cabling</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Segmento de fluxo especificamente utilizado para transportar e suportar cabos</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCableCarrierSegment.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">cable carrier segment</rdfs:label>
        <rdfs:label xml:lang="pt-br">eletrocalha</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00066 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00066">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00062"/>
        <obo:IAO_0000112>Duto para sistema HVAC</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Usado para unir duas seções de uma rede elétrica ou uma rede de componentes que transportam o serviço elétrico.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Used to typically join two sections of an electrical network or a network of components carrying the electrical service</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCableSegment.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">duct segment</rdfs:label>
        <rdfs:label xml:lang="pt-br">duto</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00067 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00067">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00062"/>
        <obo:IAO_0000112>Tubo de pvc ou cobre</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Usado para unir duas seções de uma rede de tubulação</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Used to typically join two sections of a piping network</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcPipeSegment.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">pipe segment</rdfs:label>
        <rdfs:label xml:lang="pt-br">tubulação</rdfs:label>
    </Class>
    


