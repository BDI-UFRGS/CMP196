        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00063"/>
        <obo:IAO_0000115 xml:lang="en">Junction or transition in a ducted flow distribution system or used to connect duct segments, resulting in changes in flow characteristics to the fluid such as direction and flow rate</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Junção ou transição em um sistema de distribuição de fluxo por dutos, ou é usada para conectar segmentos de dutos, resultando em mudanças nas características do fluxo do fluido, como direção e vazão</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcDuctFitting.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">conexão de dutos</rdfs:label>
        <rdfs:label xml:lang="en">duct fitting</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00071 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00071">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00063"/>
        <obo:IAO_0000115 xml:lang="en">Junction or transition in a piping flow distribution system used to connect pipe segments, resulting in changes in flow characteristics to the fluid such as direction or flow rate</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Junção ou transição em um sistema de distribuição de fluxo de tubulação usada para conectar segmentos de tubos, resultando em mudanças nas características do fluxo do fluido, como direção ou vazão</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcPipeFitting.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">conexão de tubulação</rdfs:label>
        <rdfs:label xml:lang="en">pipe fitting</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00072 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00072">
