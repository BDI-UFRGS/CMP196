                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00170"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>Uma bomba de vácuo e um multímetro são utilizado para instalação de um ar condicionado split</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Instrument used to perform a specific action or task</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Instrumento utilizado para realizar uma ação ou tarefa específica</obo:IAO_0000115>
        <rdfs:label xml:lang="pt-br">recurso de ferramenta</rdfs:label>
        <rdfs:label xml:lang="en">tool resource</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00153 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00153">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00170"/>
        <obo:IAO_0000115 xml:lang="pt-br">Tipo de dispositivo de bombeamento que extrai partículas de gás de um volume selado para deixar para trás um vácuo parcial</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Type of pump device that draws gas particles from a sealed volume in order to leave behind a partial vacuum</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Vacuum_pump</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">bomba de vácuo</rdfs:label>
        <rdfs:label xml:lang="en">vacuum pump</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00155 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00155">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00170"/>
        <obo:IAO_0000115 xml:lang="pt-br">Ferramenta utilizada por técnicos de HVAC e refrigeração para localizar vazamentos em sistemas de ar-condicionado e refrigeração.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Tool used by HVAC and refrigeration technicians to pinpoint leaks in air conditioning and refrigeration systems</obo:IAO_0000115>
        <rdfs:label xml:lang="pt-br">detector de vazamento de fluido refrigerante*</rdfs:label>
        <rdfs:label xml:lang="en">refrigerant leak detector</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00156 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00156">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00170"/>
        <obo:IAO_0000115 xml:lang="pt-br">Ferramenta utilizada por  técnicos de HVAC e refrigeração medirem a pressão, realizarem vácuo e recarregarem sistemas de ar condicionado</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Tool used by HVAC and refrigeration technicians to measure pressure, pull a vacuum, and recharge air conditioning systems</obo:IAO_0000115>
        <rdfs:label xml:lang="pt-br">conjunto de manômetros manifold</rdfs:label>
        <rdfs:label xml:lang="en">manifold gauge set</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00157 -->

