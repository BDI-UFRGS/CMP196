            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Name of the space that represents a real or theoretically bounded area or volume</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Nome do espaço que representa uma área ou volume delimitado, real ou teoricamente</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/Name</obo:IAO_0000119>
        <rdfs:label xml:lang="en">building space name</rdfs:label>
        <rdfs:label xml:lang="pt-br">nome do espaço da edificação</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00010 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00003"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000124"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00007"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty>
                    <rdf:Description>
                        <inverseOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                    </rdf:Description>
                </onProperty>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00012"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>O pavimento residencial possui uma elevação de 3 metros e agrupa os apartamentos do primeiro andar</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">A building story has an elevation and typically represents a (nearly) horizontal aggregation of vertically delimited spaces.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">O pavimento de um edifício possui uma elevação e normalmente representa uma agregação (quase) horizontal de espaços delimitados verticalmente</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcBuildingStorey</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">andar da edificação</rdfs:label>
        <rdfs:label xml:lang="en">building storey</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00011 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00011">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0000300"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00010"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Description of the building floor where the element is located</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Descrição do andar do prédio onde se encontra o elemento</obo:IAO_0000115>
        <obo:IAO_0000119>https://search.bsdd.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/Description</obo:IAO_0000119>
        <rdfs:label xml:lang="en">building storey description</rdfs:label>
        <rdfs:label xml:lang="pt-br">descrição do andar da edificação</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00012 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IAO_0020000"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000136"/>
                <qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</qualifiedCardinality>
                <onClass rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00010"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Name of the building floor that has an elevation</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Nome do pavimento de um edifício que possui uma elevação</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/Name</obo:IAO_0000119>
