            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Name of the tools required to perform the maintenance</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Nome das ferramentas necessárias para realizar a manutenção</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/prop/Name</obo:IAO_0000119>
