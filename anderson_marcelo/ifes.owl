        <obo:IAO_0000115 xml:lang="en">Fitting that is placed at junction or transition in a cable carrier system</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCableCarrierFitting.htm</obo:IAO_0000119>
