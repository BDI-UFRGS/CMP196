                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00103"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Device in which a liquid refrigerent is vaporized and absorbs heat from the surrounding fluid</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo no qual um fluido refrigerante líquido é vaporizado e absorve calor do fluido circundante</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcEvaporator.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">evaporador</rdfs:label>
        <rdfs:label xml:lang="en">evaporator</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00103 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00103">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00185"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <someValuesFrom>
                    <Class>
                        <unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00097"/>
                            <rdf:Description rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00102"/>
                        </unionOf>
                    </Class>
                </someValuesFrom>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>O ventilador centrífugo do sistema HVAC é um dispositivo que realiza trabalho mecânico no ar e induz o fluxo de ar no sistema de distribuição de climatização</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Device which imparts mechanical work on a gas. A typical usage of a fan is to induce airflow in a building services air distribution system</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo que realiza trabalho mecânico em um gás. Um uso típico de um ventilador é induzir o fluxo de ar em um sistema de distribuição de ar predial</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcFan.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">fan</rdfs:label>
        <rdfs:label xml:lang="pt-br">ventilador</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00104 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00104">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Device used to provide heat transfer between non-mixing media such as plate and shell and tube heat exchangers</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo usado para promover a transferência de calor entre meios que não se misturam, como trocadores de calor de placas e de casco e tubos</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcHeatExchanger.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00105 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00105">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="pt-br">Aparelho que adiciona umidade ao ar.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Device that adds moisture into the air</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcHumidifier.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">humidifier</rdfs:label>
        <rdfs:label xml:lang="pt-br">umidificador</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00106 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00106">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Device consisting of tubes and bundles of tubes used for heat transfer and contained typically within other energy conversion devices, such as a chiller or coil</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo constituído por tubos e feixes de tubos utilizados para transferência de calor e normalmente contidos dentro de outros dispositivos de conversão de energia, como um resfriador ou uma serpentina</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcTubeBundle.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">feixe de tubos</rdfs:label>
        <rdfs:label xml:lang="en">tube bundle</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00107 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00107">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo mecânico que converte energia elétrica em energia mecânica</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Engine that is a machine for converting electrical energy into mechanical energy</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcElectricMotor.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">electric motor</rdfs:label>
        <rdfs:label xml:lang="pt-br">motor elétrico</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00108 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00108">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="pt-br">Fornece os meios para conectar um motor, que atua como dispositivo de acionamento, ao dispositivo acionado</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Provides the means for connecting a motor as the driving device to the driven device</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcMotorConnection.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">conexão de motor</rdfs:label>
        <rdfs:label xml:lang="en">motor connection</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00109 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00109">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Engine that is a machine for converting mechanical energy into electrical energy</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Uma máquina, que converte energia mecânica em energia elétrica</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcElectricGenerator.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">electric generator</rdfs:label>
        <rdfs:label xml:lang="pt-br">gerador elétrico</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00110 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00110">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo estacionário indutivo que transfere energia elétrica de um circuito para outro</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Inductive stationary device that transfers electrical energy from one circuit to another</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcTransformer.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">transformador</rdfs:label>
        <rdfs:label xml:lang="en">transformer</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00111 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00111">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="pt-br">Converte a radiação solar em outras formas de energia, como corrente elétrica ou energia térmica</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcSolarDevice.htm</obo:IAO_0000119>
        <obo:IAO_0000424 xml:lang="en">Converts solar radiation into other energy such as electric current or thermal energy</obo:IAO_0000424>
        <rdfs:label xml:lang="pt-br">dispositivo solar</rdfs:label>
        <rdfs:label xml:lang="en">solar device</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00118 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00118">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="pt-br">Documento padronizado emitido por fabricantes que detalha as características específicas, as métricas de desempenho e as instruções de aplicação de um produto</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Standardized document issued by manufacturers that details a product’s specific characteristics, performance metrics, and application instructions</obo:IAO_0000115>
        <rdfs:label xml:lang="pt-br">ficha técnica</rdfs:label>
        <rdfs:label xml:lang="en">technical datasheet</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00119 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00119">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="en">Commercial document that includes an itemized list of goods or services furnished by a seller to a buyer relating to a sale transaction, that usually specifies the price and terms of sale, quantities, and agreed-upon prices and terms of sale for products or services the seller had provided the buyer</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Documento comercial que inclui uma relação detalhada de bens ou serviços fornecidos por um vendedor a um comprador no âmbito de uma transação de venda, especificando geralmente o preço e as condições de venda, as quantidades, bem como os preços e as condições acordados para os produtos ou serviços fornecidos pelo vendedor ao comprador</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Invoice</obo:IAO_0000119>
        <rdfs:label xml:lang="en">invoice</rdfs:label>
        <rdfs:label xml:lang="pt-br">nota fiscal</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00120 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00120">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="en">Registro técnico da obra como foi efetivamente executada, com todas as alterações em relação ao projeto original</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Technical record of the work as actually executed, including all deviations from the original design</obo:IAO_0000115>
        <obo:IAO_0000119>https://sienge.com.br/blog/as-built/</obo:IAO_0000119>
        <rdfs:label xml:lang="en">as-built</rdfs:label>
        <rdfs:label xml:lang="pt-br">como construído</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00121 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00121">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="en">Document that verifies newly installed systems (like HVAC, plumbing, or electrical) operate according to design specifications</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Documento abrangente que verifica se sistemas recém-instalados (como HVAC, hidráulica ou elétrica) operam em conformidade com as especificações de projeto</obo:IAO_0000115>
        <rdfs:label xml:lang="en">commissioning report</rdfs:label>
        <rdfs:label xml:lang="pt-br">relatório de comissionamento</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00122 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00122">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="en">Used to assist users in utilizing a specific product, service, or application</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Utilizado para auxiliar os usuários na utilização de um determinado produto, serviço ou aplicativo</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/User_guide</obo:IAO_0000119>
        <rdfs:label xml:lang="en">installation manual</rdfs:label>
        <rdfs:label xml:lang="pt-br">manual de instalação</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00124 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00124">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="en">Documentation by which an organisation provides guidance for members and employees to perform their functions correctly and reasonably efficiently</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Documentação pela qual uma organização fornece orientações aos membros e funcionários para que desempenhem suas funções de forma correta e razoavelmente eficiente</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Operations_manual</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">manual de operação</rdfs:label>
        <rdfs:label xml:lang="en">operation manual</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00125 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00125">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="en">An essential technical document that compiles procedures, standardized instructions, and safety guidelines for the maintenance of equipment, facilities, or systems</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Documento técnico essencial que reúne procedimentos, instruções padronizadas e diretrizes de segurança para conservar equipamentos, instalações ou sistemas</obo:IAO_0000115>
        <rdfs:label xml:lang="en">maintenance manual</rdfs:label>
        <rdfs:label xml:lang="pt-br">manual de manutenção</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00126 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00126">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="pt-br">Geralmente é uma tarefa ou um trabalho para um cliente , que pode ser agendado ou atribuído a alguém. Essa ordem pode ser solicitada pelo cliente ou criada internamente pela organização. Ordens de serviço também podem ser criadas como acompanhamento de inspeções ou auditorias. Uma ordem de serviço pode ser para produtos ou serviços</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Usually a task or a job for a customer, that can be scheduled or assigned to someone. Such an order may be from a customer request or created internally within the organization. Work orders may also be created as follow ups to inspections or audits. A work order may be for products or services</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Work_order</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">ordem de serviço</rdfs:label>
        <rdfs:label xml:lang="en">work order</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00127 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00127">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="pt-br">Documento formal que registra sistematicamente constatações, observações e recomendações sobre um ativo físico, propriedade ou processo específico</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Formal document that systematically records findings, observations, and recommendations about a specific physical asset, property, or process</obo:IAO_0000115>
        <rdfs:label xml:lang="en">inspection report</rdfs:label>
        <rdfs:label xml:lang="pt-br">relatório de inspeção</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00128 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00128">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00035"/>
        <obo:IAO_0000115 xml:lang="en">An official document used to track and record maintenance activities</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Um documento oficial utilizado para acompanhar e registrar atividades de manutenção</obo:IAO_0000115>
        <rdfs:label xml:lang="en">maintenance report</rdfs:label>
        <rdfs:label xml:lang="pt-br">relatório de manutenção</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00129 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00129">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00042"/>
        <obo:IAO_0000112>O sistema de climatização central é uma instalação de ar condicionado projetada para fornecer conforto térmico e controlar contaminantes por meio de refrigeração e filtragem</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Heating, ventilation, and air conditioning systems capable of regulating temperature, humidity, and indoor air quality, designed to provide thermal comfort and control airborne contaminants through heating, cooling, ventilation, filtration, and humidity control</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Sistemas de aquecimento , ventilação e ar condicionado com a capacidade de regular a temperatura , a umidade e a qualidade do ar interno sendo projetados para proporcionar conforto térmico e controlar contaminantes presentes no ar por meio de aquecimento, resfriamento, ventilação, filtragem e controle de umidade</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Heating,_ventilation,_and_air_conditioning</obo:IAO_0000119>
        <rdfs:label xml:lang="en">HVAC system</rdfs:label>
        <rdfs:label xml:lang="pt-br">sistema AVAC</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00130 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00130">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00129"/>
        <obo:IAO_0000115 xml:lang="en">A system for removing heat from an enclosed space to achieve a more comfortable indoor temperature and, in some cases, control indoor humidity.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Sistema de remoção de calor de um espaço fechado para atingir uma temperatura interna mais confortável e, em alguns casos, controlar a umidade do ar interno</obo:IAO_0000115>
        <obo:IAO_0000119>Conjunto de condicionadores de ar tipo split que compõem um sistema HVAC</obo:IAO_0000119>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Air_conditioning#Mini-split_and_multi-split_systems</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">sistema split</rdfs:label>
        <rdfs:label xml:lang="en">split system</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00150 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00150">
