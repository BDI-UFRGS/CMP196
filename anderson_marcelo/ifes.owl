    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00073 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00073">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00072"/>
        <obo:IAO_0000115 xml:lang="en">Used in a building services piping distribution system to control or modulate the flow of the fluid</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Utilizada em um sistema de distribuição de tubulações prediais para controlar ou modular o fluxo do fluido</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcValve.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00074 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00074">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00072"/>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo de proteção interrompe um circuito elétrico quando uma corrente elétrica predefinida que o atravessa é excedida</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Protective device breaks an electrical circuit when a stated electric current that passes through it is exceeded</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcProtectiveDevice.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">dispositivo de proteção</rdfs:label>
        <rdfs:label xml:lang="en">protective device</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00075 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00075">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00072"/>
        <obo:IAO_0000115 xml:lang="pt-br">Controlador de fluxo no qual diversos dispositivos elétricos ou de comunicação são reunidos em um único local para uma finalidade específica</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Flow controller in which instances of electrical or communication devices are brought together at a single place for a particular purpose</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcDistributionBoard.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">distribution board</rdfs:label>
        <rdfs:label xml:lang="pt-br">quadro de distribuição</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00076 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00076">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00072"/>
        <obo:IAO_0000115 xml:lang="pt-br">Usado em um sistema de distribuição de cabos (circuito elétrico) para controlar ou modular o fluxo de eletricidade</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Used in a cable distribution system (electrical circuit) to control or modulate the flow of electricity</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcSwitchingDevice.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">dispositivo de manobra</rdfs:label>
        <rdfs:label xml:lang="en">switching device</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00077 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00077">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00072"/>
        <obo:IAO_0000115 xml:lang="pt-br">Faz parte de um sistema de distribuição de dutos de HVAC e é usada para controlar ou modular a quantidade de ar fornecida aos dutos subsequentes</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Typically participates in an HVAC duct distribution system and is used to control or modulate the amount of air delivered to its downstream ductwork</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcAirTerminalBox.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">air terminal box</rdfs:label>
        <rdfs:label xml:lang="pt-br">regulador de fluxo de ar</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00078 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00078">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00051"/>
        <obo:IAO_0000112>Um tanque de armazenamento de fluído</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Device that participates in a distribution system and is used for temporary storage</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo que participa de um sistema de distribuição e é usado para armazenamento temporário</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcFlowStorageDevice.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">armazenamento de sistema de distribuição</rdfs:label>
        <rdfs:label xml:lang="en">flow storage</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00079 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00079">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00078"/>
        <obo:IAO_0000115 xml:lang="pt-br">Recipiente ou contêiner no qual um fluido ou gás é armazenado para uso posterior</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Vessel or container in which a fluid or gas is stored for later use</obo:IAO_0000115>
        <obo:IAO_0000119>A caixa d&apos;água utilizada com reservatório de abastecimento</obo:IAO_0000119>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcTank.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">reservatório</rdfs:label>
        <rdfs:label xml:lang="en">tank</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00080 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00080">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00078"/>
        <obo:IAO_0000112>O banco de baterias é um dispositivo de armazenamento de fluxo elétrico no qual a energia elétrica é acumulada e de onde pode ser liberada progressivamente</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo de armazenamento de fluxo elétrico é um dispositivo no qual a energia elétrica é armazenada e do qual a energia pode ser liberada progressivamente</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Electric flow storage device is a device in which electrical energy is stored and from which energy may be progressively released</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcElectricFlowStorageDevice.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">dispositivo de armazenamento elétrico</rdfs:label>
        <rdfs:label xml:lang="en">electric storage device</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00081 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00081">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00051"/>
        <obo:IAO_0000115 xml:lang="en">Acts as the terminal point or the starting point of a distribution system</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Atua como terminal ou início de um sistema de distribuição</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcFlowTerminal.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">flow terminal</rdfs:label>
        <rdfs:label xml:lang="pt-br">terminal de sistema de distribuição</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00082 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00082">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <obo:IAO_0000112>Difusor de teto é um terminal de ar que realiza a transferência de fluxo de climatização entre os dutos e as salas de escritório</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Ponto de origem ou de término para a transferência de ar entre um ou mais sistemas de distribuição e um ou mais ambientes</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">terminating or origination point for the transfer of air between distribution system(s) and one or more spaces. It can also be used for the transfer of air between adjacent spaces</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcAirTerminal.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">air terminal</rdfs:label>
        <rdfs:label xml:lang="pt-br">terminal de ar</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00083 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00083">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <obo:IAO_0000112>Torneira de jardim</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Terminating or origination point for the transfer of liquid between distribution system(s). this is the point where the liquid distribution system interacts with the external environment</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">onto de origem ou de término para a transferência de líquidos entre sistemas de distribuição. É o ponto onde o sistema de distribuição de líquidos interage com o ambiente externo</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcLiquidTerminal.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">liquid terminal</rdfs:label>
        <rdfs:label xml:lang="pt-br">terminal hidráulico</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00084 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00084">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <obo:IAO_0000112>O vaso sanitário é um terminal sanitário</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Aparelho ou terminal fixo, geralmente abastecido com água e usado para beber, limpar ou descartar águas residuais, ou um equipamento usado diretamente com tal aparelho ou terminal</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Fixed appliance or terminal usually supplied with water and used for drinking, cleaning or foul water disposal or that is an item of equipment directly used with such an appliance or terminal</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcSanitaryTerminal.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">sanitary terminal</rdfs:label>
        <rdfs:label xml:lang="pt-br">terminal sanitário</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00085 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00085">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <obo:IAO_0000112>Caixa de inspeção de esgoto que coleta os efluentes da rede sanitária domiciliar</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="pt-br">Terminal de resíduos tem como objetivo coletar ou interceptar resíduos de um ou mais terminais sanitários ou outros equipamentos geradores de resíduos líquidos e descarregá-los em um único sistema de esgoto/drenagem</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="en">Waste terminal has the purpose of collecting or intercepting waste from one or more sanitary terminals or other fluid waste generating equipment and discharging it into a single waste/drainage system.</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcWasteTerminal.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">terminal de descarte</rdfs:label>
        <rdfs:label xml:lang="en">waste terminal</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00086 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00086">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00051"/>
        <obo:IAO_0000115 xml:lang="en">Device used to perform energy conversion or heat transfer and typically participates in a flow distribution system</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo utilizado para realizar conversão de energia ou transferência de calor e que tipicamente participa de um sistema de distribuição de fluxo</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcEnergyConversionDevice.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">dispositivo de conversão de energia</rdfs:label>
        <rdfs:label xml:lang="en">energy conversion device</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00087 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00087">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <obo:IAO_0000112>Luminária da sala 101</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Container that is designed for the purpose of housing one or more lamps and optionally devices that control, restrict or vary their emission</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Recipiente projetado para abrigar uma ou mais lâmpadas e, opcionalmente, dispositivos que controlam, restringem ou variam sua emissão</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcLightFixture.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">light fixture</rdfs:label>
        <rdfs:label xml:lang="pt-br">luminária</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00088 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00088">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <obo:IAO_0000112>Lâmpada fluorescente da sala 101</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Artificial light source such as a light bulb or tube</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Fonte de luz artificial, como uma lâmpada incandescente ou fluorescente</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcLamp.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">lamp</rdfs:label>
        <rdfs:label xml:lang="pt-br">lâmpada</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00089 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00089">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <obo:IAO_0000112>Projetor instalado na sala de aula</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Device that displays, captures, transmits, or receives audio or video</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo que exibe, captura, transmite ou recebe áudio ou vídeo</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcAudioVisualAppliance.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">aparelho audiovisual</rdfs:label>
        <rdfs:label xml:lang="en">audio visual appliance</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00090 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00090">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <obo:IAO_0000112>Tomada de alimentação elétrica de 220V</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Fixed in place or may be able to be moved from one space to another. Electric appliances require an electrical supply that may be supplied either by an electrical circuit or provided from a local battery source</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Fixos ou podem ser movidos de um cômodo para outro. Eles requerem uma fonte de alimentação elétrica, que pode ser fornecida por um circuito elétrico ou por uma bateria</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcElectricAppliance.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">electrical outlet</rdfs:label>
        <rdfs:label xml:lang="pt-br">tomada</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00091 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00091">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Air-to-air heat recovery device employs a counter-flow heat exchanger between inbound and outbound air flow</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo de recuperação de calor ar-ar que utiliza um trocador de calor de contracorrente entre o fluxo de ar de entrada e o de saída</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcAirToAirHeatRecovery.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">air heat recovery</rdfs:label>
        <rdfs:label xml:lang="pt-br">dispositivo de conversão de energia</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00092 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00092">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00081"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00102"/>
            </Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">Device composed of fibrous or porous materials which removes particulates such as smoke, dust, pollen, mold, viruses, and bacteria from the air</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo composto de materiais fibrosos ou porosos que remove partículas como fumaça , poeira , pólen , mofo , vírus e bactérias do ar</obo:IAO_0000115>
        <obo:IAO_0000119>Filtro de ar condicionado split</obo:IAO_0000119>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Air_filter</obo:IAO_0000119>
        <rdfs:label xml:lang="en">air filter</rdfs:label>
        <rdfs:label xml:lang="pt-br">filtro de ar</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00093 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00093">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Closed, pressure-rated vessel in which water or other fluid is heated using an energy source such as natural gas, heating oil, or electricity</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Recipiente fechado, com pressão nominal, no qual a água ou outro fluido é aquecido utilizando uma fonte de energia como gás natural, óleo combustível ou eletricidade</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcBoiler.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">boiler</rdfs:label>
        <rdfs:label xml:lang="pt-br">boiler</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00094 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00094">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Device that converts fuel into heat through combustion. It includes gas, oil, and wood burners</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo que converte combustível em calor por meio da combustão. Inclui queimadores a gás, a óleo e a lenha</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcBurner.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">burner</rdfs:label>
        <rdfs:label xml:lang="pt-br">queimador</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00095 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00095">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Device used to remove heat from a liquid via a vapor-compression or absorption refrigeration cycle to cool a fluid, typically water or a mixture of water and glycol</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo usado para remover o calor de um líquido por meio de um ciclo de refrigeração por compressão de vapor ou absorção, resfriando um fluido, geralmente água ou uma mistura de água e glicol</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcChiller.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">chiller</rdfs:label>
        <rdfs:label xml:lang="pt-br">chiller</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00096 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00096">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <obo:IAO_0000115 xml:lang="en">Device used to provide heat transfer between non-mixing media</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Dispositivo usado para promover a transferência de calor entre meios que não se misturam</obo:IAO_0000115>
        <obo:IAO_0000119>https://standards.buildingsmart.org/IFC/RELEASE/IFC4_3/HTML/lexical/IfcCoil.htm</obo:IAO_0000119>
        <rdfs:label xml:lang="en">coil</rdfs:label>
        <rdfs:label xml:lang="pt-br">serpentina</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00097 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00097">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00086"/>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00182"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
                <onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <someValuesFrom rdf:resource="http://www.semanticweb.org/2026/5/ifes/IFES_00100"/>
            </Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <Restriction>
