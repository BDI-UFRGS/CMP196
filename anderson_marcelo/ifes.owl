        <obo:IAO_0000115 xml:lang="en">These are the spare parts and consumables required for each of the managed assets</obo:IAO_0000115>
        <rdfs:label xml:lang="pt-br">peça de reposição</rdfs:label>
        <rdfs:label xml:lang="en">spare part</rdfs:label>
    </Class>
    


