        <obo:IAO_0000115 xml:lang="en">Measuring instrument that can measure multiple electrical properties</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Multimeter</obo:IAO_0000119>
        <rdfs:label xml:lang="en">multimeter</rdfs:label>
        <rdfs:label xml:lang="pt-br">multimetro</rdfs:label>
    </Class>
    


    <!-- http://www.semanticweb.org/2026/5/ifes/IFES_00158 -->

    <Class rdf:about="http://www.semanticweb.org/2026/5/ifes/IFES_00158">
