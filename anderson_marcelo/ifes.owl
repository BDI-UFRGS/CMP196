        <obo:IAO_0000112>Troca do filtro de ar do ar condicionado split na sala 102</obo:IAO_0000112>
        <obo:IAO_0000115 xml:lang="en">Identifiable unit of work to be performed in a construction project.</obo:IAO_0000115>
        <obo:IAO_0000115 xml:lang="pt-br">Unidade de trabalho identificável a ser executada em um projeto de construção</obo:IAO_0000115>
        <obo:IAO_0000119>https://identifier.buildingsmart.org/uri/buildingsmart/ifc/4.3/class/IfcTask</obo:IAO_0000119>
        <rdfs:label xml:lang="pt-br">tarefa</rdfs:label>
        <rdfs:label xml:lang="en">task</rdfs:label>
    </Class>
    


